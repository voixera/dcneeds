# Bot ini membaca .env di root workspace discordresource/.
# Gunakan DISCORD_FIFA_TOKEN untuk bot khusus FIFA, atau DISCORD_BOT_TOKEN
# jika ingin memakai token bot utama yang sudah ada.
DISCORD_FIFA_TOKEN=your_discord_bot_token
DISCORD_FIFA_CLIENT_ID=your_discord_application_client_id

# Optional. Isi agar slash command langsung muncul di server test.
DISCORD_FIFA_GUILD_ID=your_test_guild_id

# Optional. Channel untuk notifikasi jadwal dan hasil pertandingan.
DISCORD_FIFA_NOTIFICATION_CHANNEL_ID=your_notification_channel_id

DISCORD_FIFA_TIMEZONE=Asia/Jakarta
DISCORD_FIFA_NOTIFICATION_LOOKAHEAD_MINUTES=30
DISCORD_FIFA_NOTIFICATION_INTERVAL_SECONDS=60

# Optional. Railway worker akan mengisi otomatis jika PERSISTENT_DATA_DIR aktif.
FIFA_DB_PATH=

# Live answer: ChatGPT/OpenAI Responses API dengan web search bawaan.
FIFA_LIVE_ANSWERS_ENABLED=true
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.5
